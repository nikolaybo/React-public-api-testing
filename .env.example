# BigBook API key — used only by the Vite dev-server proxy (Node side).
# NEVER prefix with VITE_ — that would bundle the key into the client.
#
# For production deploy the same proxy logic must be re-implemented in your
# hosting layer (Cloudflare Worker, Vercel function, Express middleware, etc.)
# so the browser still never sees the key.
BIGBOOK_API_KEY=your-bigbook-api-key-here
